# MCP Memory Service
MCP_MEMORY_CHROMA_PATH=/data/memory
MCP_MEMORY_BACKUPS_PATH=/data/backups
MCP_SSE_HOST=0.0.0.0
MCP_SSE_PORT=8765
MCP_STREAMABLE_HTTP_MODE=1
MCP_OAUTH_ENABLED=false

# Cloudflare Tunnel
# Get from: Cloudflare Dashboard → Zero Trust → Networks → Tunnels → your tunnel → Configure → Install connector
TUNNEL_TOKEN=your-tunnel-token-here

# Cloudflare Access Service Token (for Claude Code and automated clients)
# Get from: Cloudflare Dashboard → Zero Trust → Access → Service Auth → Create Service Token
# The Client ID ends in ".access"
CF_ACCESS_CLIENT_ID=your-service-token-client-id.access
CF_ACCESS_CLIENT_SECRET=your-service-token-client-secret
